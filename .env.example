# Session signing secret (required in production — use a long random string)
SESSION_SECRET=

# API port (default 3001 — must match Vite proxy in vite.config.ts)
PORT=3001

# Optional: SQLite database file path (default: ./data/astranotes.db)
# ASTRANOTES_DB_PATH=

# SQLite journal mode: WAL (default on local disks), DELETE or TRUNCATE.
# If the project or DB path is on SMB/NAS, a UNC path (\\server\share), or a Windows drive
# letter mapped to a network share, the API auto-selects DELETE — WAL is not reliable on
# network filesystems (this is not about "sync"; direct SMB still needs DELETE).
# Force WAL only when you are sure the DB file is on a real local disk:
# ASTRANOTES_SQLITE_JOURNAL_MODE=WAL

# Docker Compose: copy this file to ".env" if you want the same variables when running
# `docker compose up`. You can also add `env_file: [.env]` under the `app` service in
# docker-compose.yml (Compose requires the file to exist if listed).
